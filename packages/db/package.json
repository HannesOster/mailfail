{
  "name": "@mailfail/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./sqlite": "./src/sqlite.ts",
    "./src/queries/*": "./src/queries/*.ts",
    "./src/*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.39",
    "@neondatabase/serverless": "^0.10",
    "@mailfail/shared": "workspace:*",
    "better-sqlite3": "^11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "drizzle-kit": "^0.30",
    "typescript": "^5"
  }
}
